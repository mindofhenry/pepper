# Pepper environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Core (book club) ---

# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Neon Postgres connection string (postgresql://user:pass@host/db?sslmode=require)
DATABASE_URL=

# Anthropic API key for Haiku-generated discussion prompts
ANTHROPIC_API_KEY=

# Google Books API key for /book search and /poll nominate
GOOGLE_BOOKS_API_KEY=

# Discord guild (server) ID. Set during dev for instant slash command sync.
# Leave unset in prod so commands sync globally (takes up to an hour).
TEST_GUILD_ID=

# Discord channel ID for cog error reports (private channel only Henry sees).
# Required for per-cog failure isolation reports to land somewhere visible.
ADMIN_CHANNEL_ID=


# --- Media (Phase 12+) ---
# Below are loaded but unused until the media cogs land. Keep them blank
# unless you're working on Phase 12.

# qBittorrent Web UI (typically http://localhost:8080)
QB_HOST=
QB_USER=
QB_PASS=

# Prowlarr base URL and API key (Settings > General > Security)
PROWLARR_URL=
PROWLARR_API_KEY=

# Path on the Mini-PC external drive where completed downloads land
# before being scanned and moved into the Jellyfin library
STAGING_DIR=

# Jellyfin base URL and API key for library scan trigger
JELLYFIN_URL=
JELLYFIN_API_KEY=

# ClamAV daemon host (host:port or unix socket path)
CLAMAV_HOST=

# Comma-separated Discord user IDs allowed to run /media commands.
# This bot is not a public download proxy; only whitelisted users get media.
MEDIA_USER_WHITELIST=
